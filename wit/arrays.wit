/// Arrow array types and operations
interface arrays {
    use types.{data-type, schema, field, arrow-error, time-unit};

    /// A generic Arrow array (type-erased)
    resource array {
        /// Get the data type of the array
        data-type: func() -> data-type;

        /// Get the number of elements
        len: func() -> u64;

        /// Check if the array is empty
        is-empty: func() -> bool;

        /// Get the number of null values
        null-count: func() -> u64;

        /// Check if a specific index is null
        is-null: func(index: u64) -> bool;

        /// Check if a specific index is valid (not null)
        is-valid: func(index: u64) -> bool;

        /// Slice the array
        slice: func(offset: u64, length: u64) -> array;

        /// Get the memory size in bytes
        get-buffer-memory-size: func() -> u64;

        /// Get the array memory size in bytes
        get-array-memory-size: func() -> u64;
    }

    /// Builder for boolean arrays
    resource boolean-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> boolean-array-builder;
        append-value: func(value: bool);
        append-null: func();
        append-values: func(values: list<bool>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Int8 arrays
    resource int8-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> int8-array-builder;
        append-value: func(value: s8);
        append-null: func();
        append-values: func(values: list<s8>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Int16 arrays
    resource int16-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> int16-array-builder;
        append-value: func(value: s16);
        append-null: func();
        append-values: func(values: list<s16>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Int32 arrays
    resource int32-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> int32-array-builder;
        append-value: func(value: s32);
        append-null: func();
        append-values: func(values: list<s32>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Int64 arrays
    resource int64-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> int64-array-builder;
        append-value: func(value: s64);
        append-null: func();
        append-values: func(values: list<s64>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for UInt8 arrays
    resource uint8-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> uint8-array-builder;
        append-value: func(value: u8);
        append-null: func();
        append-values: func(values: list<u8>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for UInt16 arrays
    resource uint16-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> uint16-array-builder;
        append-value: func(value: u16);
        append-null: func();
        append-values: func(values: list<u16>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for UInt32 arrays
    resource uint32-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> uint32-array-builder;
        append-value: func(value: u32);
        append-null: func();
        append-values: func(values: list<u32>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for UInt64 arrays
    resource uint64-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> uint64-array-builder;
        append-value: func(value: u64);
        append-null: func();
        append-values: func(values: list<u64>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Float32 arrays
    resource float32-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> float32-array-builder;
        append-value: func(value: f32);
        append-null: func();
        append-values: func(values: list<f32>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Float64 arrays
    resource float64-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> float64-array-builder;
        append-value: func(value: f64);
        append-null: func();
        append-values: func(values: list<f64>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for String arrays
    resource string-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> string-array-builder;
        append-value: func(value: string);
        append-null: func();
        append-option: func(value: option<string>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Binary arrays
    resource binary-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> binary-array-builder;
        append-value: func(value: list<u8>);
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// ========== Large String/Binary Builders ==========

    /// Builder for LargeString arrays (supports strings > 2GB total)
    resource large-string-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> large-string-array-builder;
        append-value: func(value: string);
        append-null: func();
        append-option: func(value: option<string>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for LargeBinary arrays (supports binary data > 2GB total)
    resource large-binary-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> large-binary-array-builder;
        append-value: func(value: list<u8>);
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for FixedSizeBinary arrays
    resource fixed-size-binary-array-builder {
        /// Create with specified byte width
        constructor(byte-width: u32);
        append-value: func(value: list<u8>) -> result<_, arrow-error>;
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for List arrays (variable-length lists of values)
    resource list-array-builder {
        /// Create with value data type
        constructor(value-type: data-type);
        append-null: func();
        /// Append a list of i64 values
        append-values-i64: func(values: list<s64>);
        /// Append a list of f64 values
        append-values-f64: func(values: list<f64>);
        /// Append a list of string values
        append-values-string: func(values: list<string>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for LargeList arrays (lists with 64-bit offsets for > 2GB total values)
    resource large-list-array-builder {
        /// Create with value data type
        constructor(value-type: data-type);
        append-null: func();
        /// Append a list of i64 values
        append-values-i64: func(values: list<s64>);
        /// Append a list of f64 values
        append-values-f64: func(values: list<f64>);
        /// Append a list of string values
        append-values-string: func(values: list<string>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Struct arrays
    resource struct-array-builder {
        /// Create with field definitions
        constructor(fields: list<tuple<string, data-type>>);
        /// Append a value to a specific field (by index) - Int64
        append-field-i64: func(field-index: u32, value: option<s64>) -> result<_, arrow-error>;
        /// Append a value to a specific field - Float64
        append-field-f64: func(field-index: u32, value: option<f64>) -> result<_, arrow-error>;
        /// Append a value to a specific field - String
        append-field-string: func(field-index: u32, value: option<string>) -> result<_, arrow-error>;
        /// Append a value to a specific field - Boolean
        append-field-bool: func(field-index: u32, value: option<bool>) -> result<_, arrow-error>;
        /// Complete the current struct row (call after appending all fields)
        append-row: func() -> result<_, arrow-error>;
        /// Append a null struct
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Map arrays
    resource map-array-builder {
        /// Create with key and value types (keys are typically strings)
        constructor(key-type: data-type, value-type: data-type);
        /// Start a new map entry
        start-map: func();
        /// Append a key-value pair with string key and i64 value
        append-entry-string-i64: func(key: string, value: option<s64>);
        /// Append a key-value pair with string key and f64 value
        append-entry-string-f64: func(key: string, value: option<f64>);
        /// Append a key-value pair with string key and string value
        append-entry-string-string: func(key: string, value: option<string>);
        /// End current map entry
        end-map: func();
        /// Append a null map
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// ========== Temporal Type Builders ==========

    /// Builder for Date32 arrays (days since epoch)
    resource date32-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> date32-array-builder;
        append-value: func(value: s32);
        append-null: func();
        append-values: func(values: list<s32>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Date64 arrays (milliseconds since epoch)
    resource date64-array-builder {
        constructor();
        with-capacity: static func(capacity: u64) -> date64-array-builder;
        append-value: func(value: s64);
        append-null: func();
        append-values: func(values: list<s64>, is-valid: list<bool>);
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Timestamp arrays
    resource timestamp-array-builder {
        /// Create a timestamp builder with unit and optional timezone
        constructor(unit: time-unit, timezone: option<string>);
        append-value: func(value: s64);
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Duration arrays
    resource duration-array-builder {
        /// Create a duration builder with unit
        constructor(unit: time-unit);
        append-value: func(value: s64);
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Time32 arrays
    resource time32-array-builder {
        /// Create a time32 builder with unit (second or millisecond)
        constructor(unit: time-unit);
        append-value: func(value: s32);
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Time64 arrays
    resource time64-array-builder {
        /// Create a time64 builder with unit (microsecond or nanosecond)
        constructor(unit: time-unit);
        append-value: func(value: s64);
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// ========== Decimal Type Builders ==========

    /// Builder for Decimal128 arrays (128-bit precision decimals)
    resource decimal128-array-builder {
        /// Create a decimal128 builder with precision (total digits) and scale (digits after decimal point)
        constructor(precision: u8, scale: s8);
        /// Append value as string (e.g., "123.45" or "-9999.99")
        append-value-string: func(value: string) -> result<_, arrow-error>;
        /// Append value from high and low 64-bit parts (for direct i128 representation)
        append-value-i128: func(high: s64, low: u64);
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Builder for Decimal256 arrays (256-bit precision decimals)
    resource decimal256-array-builder {
        /// Create a decimal256 builder with precision and scale
        constructor(precision: u8, scale: s8);
        /// Append value as bytes (32 bytes, little-endian)
        append-value-bytes: func(value: list<u8>) -> result<_, arrow-error>;
        append-null: func();
        len: func() -> u64;
        finish: func() -> array;
    }

    /// Create an array from typed data
    /// These functions provide convenient ways to create arrays from data

    /// Create a boolean array from values
    boolean-array-from: func(values: list<bool>) -> array;

    /// Create an Int32 array from values
    int32-array-from: func(values: list<s32>) -> array;

    /// Create an Int64 array from values
    int64-array-from: func(values: list<s64>) -> array;

    /// Create a Float64 array from values
    float64-array-from: func(values: list<f64>) -> array;

    /// Create a String array from values
    string-array-from: func(values: list<string>) -> array;

    /// Create a nullable Int32 array
    int32-array-from-nullable: func(values: list<option<s32>>) -> array;

    /// Create a nullable Int64 array
    int64-array-from-nullable: func(values: list<option<s64>>) -> array;

    /// Create a nullable Float64 array
    float64-array-from-nullable: func(values: list<option<f64>>) -> array;

    /// Create a nullable String array
    string-array-from-nullable: func(values: list<option<string>>) -> array;

    /// Array accessor functions
    /// Get values from arrays (returns error if wrong type or out of bounds)

    /// Get a boolean value
    get-boolean: func(arr: borrow<array>, index: u64) -> result<option<bool>, arrow-error>;

    /// Get an Int8 value
    get-int8: func(arr: borrow<array>, index: u64) -> result<option<s8>, arrow-error>;

    /// Get an Int16 value
    get-int16: func(arr: borrow<array>, index: u64) -> result<option<s16>, arrow-error>;

    /// Get an Int32 value
    get-int32: func(arr: borrow<array>, index: u64) -> result<option<s32>, arrow-error>;

    /// Get an Int64 value
    get-int64: func(arr: borrow<array>, index: u64) -> result<option<s64>, arrow-error>;

    /// Get a UInt8 value
    get-uint8: func(arr: borrow<array>, index: u64) -> result<option<u8>, arrow-error>;

    /// Get a UInt16 value
    get-uint16: func(arr: borrow<array>, index: u64) -> result<option<u16>, arrow-error>;

    /// Get a UInt32 value
    get-uint32: func(arr: borrow<array>, index: u64) -> result<option<u32>, arrow-error>;

    /// Get a UInt64 value
    get-uint64: func(arr: borrow<array>, index: u64) -> result<option<u64>, arrow-error>;

    /// Get a Float32 value
    get-float32: func(arr: borrow<array>, index: u64) -> result<option<f32>, arrow-error>;

    /// Get a Float64 value
    get-float64: func(arr: borrow<array>, index: u64) -> result<option<f64>, arrow-error>;

    /// Get a String value
    get-string: func(arr: borrow<array>, index: u64) -> result<option<string>, arrow-error>;

    /// Get a Binary value
    get-binary: func(arr: borrow<array>, index: u64) -> result<option<list<u8>>, arrow-error>;

    /// ========== Temporal Accessors ==========

    /// Get a Date32 value (days since epoch)
    get-date32: func(arr: borrow<array>, index: u64) -> result<option<s32>, arrow-error>;

    /// Get a Date64 value (milliseconds since epoch)
    get-date64: func(arr: borrow<array>, index: u64) -> result<option<s64>, arrow-error>;

    /// Get a Timestamp value
    get-timestamp: func(arr: borrow<array>, index: u64) -> result<option<s64>, arrow-error>;

    /// Get a Duration value
    get-duration: func(arr: borrow<array>, index: u64) -> result<option<s64>, arrow-error>;

    /// Get a Time32 value
    get-time32: func(arr: borrow<array>, index: u64) -> result<option<s32>, arrow-error>;

    /// Get a Time64 value
    get-time64: func(arr: borrow<array>, index: u64) -> result<option<s64>, arrow-error>;

    /// ========== Decimal Accessors ==========

    /// Get a Decimal128 value as string (formatted with decimal point)
    get-decimal128-as-string: func(arr: borrow<array>, index: u64) -> result<option<string>, arrow-error>;

    /// Get a Decimal128 value as high and low 64-bit parts (for direct i128 representation)
    get-decimal128-i128: func(arr: borrow<array>, index: u64) -> result<option<tuple<s64, u64>>, arrow-error>;

    /// Get a Decimal256 value as bytes (32 bytes, little-endian)
    get-decimal256-bytes: func(arr: borrow<array>, index: u64) -> result<option<list<u8>>, arrow-error>;

    /// Concatenate multiple arrays of the same type
    concat: func(arrays: list<array>) -> result<array, arrow-error>;

    /// ========== Dictionary Array Operations ==========

    /// Encode an array as dictionary-encoded (returns original if already dictionary-encoded)
    dictionary-encode: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Decode a dictionary-encoded array to its plain form
    dictionary-decode: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get the keys array from a dictionary-encoded array
    dictionary-keys: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get the values (dictionary) array from a dictionary-encoded array
    dictionary-values: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// ========== List Array Operations ==========

    /// Get the length of each list element
    list-lengths: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get the values array from a list array (flattened)
    list-values: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Flatten a nested list array by one level
    list-flatten: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Unnest/explode a list array into individual elements with row indices
    /// Returns a record batch with columns: "index" (original row index) and "value" (unnested values)
    unnest-list: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Check if list contains a value (returns boolean array)
    list-contains-i64: func(arr: borrow<array>, value: s64) -> result<array, arrow-error>;

    /// Check if list contains a float value
    list-contains-f64: func(arr: borrow<array>, value: f64) -> result<array, arrow-error>;

    /// Check if list contains a string value
    list-contains-string: func(arr: borrow<array>, value: string) -> result<array, arrow-error>;

    /// Get list element at index (returns array with values or nulls for out-of-bounds)
    /// Negative indices count from the end of each list
    list-element: func(arr: borrow<array>, index: s64) -> result<array, arrow-error>;

    /// Create a list array from multiple arrays (each array becomes one list element)
    arrays-to-list: func(arrays: list<array>) -> result<array, arrow-error>;

    /// ========== Struct Array Operations ==========

    /// Get a field from a struct array by index
    struct-field: func(arr: borrow<array>, index: u32) -> result<array, arrow-error>;

    /// Get a field from a struct array by name
    struct-field-by-name: func(arr: borrow<array>, name: string) -> result<array, arrow-error>;

    /// Get all field names from a struct array
    struct-field-names: func(arr: borrow<array>) -> result<list<string>, arrow-error>;

    /// Get the number of fields in a struct array
    struct-num-fields: func(arr: borrow<array>) -> result<u32, arrow-error>;

    /// ========== Map Array Operations ==========

    /// Get the keys array from a map array
    map-keys: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get the values array from a map array
    map-values: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get the offsets array from a map array (for understanding map boundaries)
    map-offsets: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// ========== FixedSizeList Array Operations ==========

    /// Get the values array from a fixed-size list array (flattened)
    fixed-list-values: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get the fixed size of the list elements
    fixed-list-size: func(arr: borrow<array>) -> result<u32, arrow-error>;

    /// ========== Union Array Operations ==========

    /// Get the type IDs array from a union array
    union-type-ids: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get a child array from a union by type id
    union-child: func(arr: borrow<array>, type-id: u8) -> result<array, arrow-error>;

    /// Get all child arrays from a union
    union-children: func(arr: borrow<array>) -> result<list<array>, arrow-error>;

    /// ========== Run-End Encoded Array Operations ==========

    /// Encode an array as run-end encoded (compresses repeated values)
    ree-encode: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Decode a run-end encoded array to its plain form
    ree-decode: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get the run ends array from a run-end encoded array
    ree-run-ends: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get the values array from a run-end encoded array
    ree-values: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// ========== Binary Data Operations ==========

    /// Get byte at specified index from each binary element (returns Int32 array of byte values)
    binary-get-byte: func(arr: borrow<array>, index: u64) -> result<array, arrow-error>;

    /// Slice binary data from each element (start can be negative for from-end indexing)
    binary-slice: func(arr: borrow<array>, start: s64, length: option<u64>) -> result<array, arrow-error>;

    /// Concatenate two binary arrays element-wise
    binary-concat: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Get length of each binary element (returns Int64 array)
    binary-length: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Convert binary array to hex string array
    binary-to-hex: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Convert hex string array to binary array
    hex-to-binary: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// ========== Array Generation Utilities ==========

    /// Create an array filled with a repeated Int64 value
    repeat-i64: func(value: s64, count: u64) -> array;

    /// Create an array filled with a repeated Float64 value
    repeat-f64: func(value: f64, count: u64) -> array;

    /// Create an array filled with a repeated String value
    repeat-string: func(value: string, count: u64) -> array;

    /// Create an array filled with a repeated Boolean value
    repeat-bool: func(value: bool, count: u64) -> array;

    /// Generate a sequence of Int64 values from start to stop (exclusive) with step
    range-i64: func(start: s64, stop: s64, step: s64) -> result<array, arrow-error>;

    /// Generate a sequence of Float64 values from start to stop (exclusive) with step
    range-f64: func(start: f64, stop: f64, step: f64) -> result<array, arrow-error>;

    /// Generate a sequence of Date32 values from start to stop (exclusive) with step in days
    range-date: func(start: s32, stop: s32, step: s32) -> result<array, arrow-error>;
}
