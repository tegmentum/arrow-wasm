/// Arrow compute kernels - wrapping arrow-rs functionality
interface compute {
    use types.{arrow-error, data-type, time-unit};
    use arrays.{array};
    use record-batch.{record-batch};

    // ========================================================================
    // Arithmetic Operations (arrow-arith)
    // ========================================================================

    /// Add two arrays element-wise
    add: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Subtract two arrays element-wise
    subtract: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Multiply two arrays element-wise
    multiply: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Divide two arrays element-wise
    divide: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Modulo (remainder) of two arrays element-wise
    modulo: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Negate array values
    negate: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Add with wrapping overflow behavior
    add-wrapping: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Subtract with wrapping overflow behavior
    subtract-wrapping: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Multiply with wrapping overflow behavior
    multiply-wrapping: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Negate with wrapping overflow behavior
    negate-wrapping: func(arr: borrow<array>) -> result<array, arrow-error>;

    // ========================================================================
    // Aggregation Operations (arrow-arith aggregate)
    // ========================================================================

    /// Sum of numeric array (returns i64)
    sum-i64: func(arr: borrow<array>) -> result<option<s64>, arrow-error>;

    /// Sum of numeric array (returns f64)
    sum-f64: func(arr: borrow<array>) -> result<option<f64>, arrow-error>;

    /// Minimum value in numeric array (returns i64)
    min-i64: func(arr: borrow<array>) -> result<option<s64>, arrow-error>;

    /// Minimum value in numeric array (returns f64)
    min-f64: func(arr: borrow<array>) -> result<option<f64>, arrow-error>;

    /// Maximum value in numeric array (returns i64)
    max-i64: func(arr: borrow<array>) -> result<option<s64>, arrow-error>;

    /// Maximum value in numeric array (returns f64)
    max-f64: func(arr: borrow<array>) -> result<option<f64>, arrow-error>;

    /// Minimum string value
    min-string: func(arr: borrow<array>) -> result<option<string>, arrow-error>;

    /// Maximum string value
    max-string: func(arr: borrow<array>) -> result<option<string>, arrow-error>;

    /// Boolean AND aggregate (all true)
    bool-and: func(arr: borrow<array>) -> result<option<bool>, arrow-error>;

    /// Boolean OR aggregate (any true)
    bool-or: func(arr: borrow<array>) -> result<option<bool>, arrow-error>;

    // ========================================================================
    // Comparison Operations (arrow-ord)
    // ========================================================================

    /// Comparison operator
    enum compare-op {
        equal,
        not-equal,
        less-than,
        less-than-or-equal,
        greater-than,
        greater-than-or-equal,
    }

    /// Compare two arrays element-wise
    compare: func(left: borrow<array>, right: borrow<array>, op: compare-op) -> result<array, arrow-error>;

    /// Compare array to scalar i64
    compare-scalar-i64: func(arr: borrow<array>, value: s64, op: compare-op) -> result<array, arrow-error>;

    /// Compare array to scalar f64
    compare-scalar-f64: func(arr: borrow<array>, value: f64, op: compare-op) -> result<array, arrow-error>;

    /// Compare array to scalar string
    compare-scalar-string: func(arr: borrow<array>, value: string, op: compare-op) -> result<array, arrow-error>;

    /// Check if values are distinct (treats nulls as equal)
    distinct: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Check if values are not distinct
    not-distinct: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    // ========================================================================
    // Boolean Operations (arrow-arith boolean)
    // ========================================================================

    /// Boolean AND of two arrays
    and: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Boolean OR of two arrays
    or: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Boolean NOT of array
    not: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Boolean AND NOT (left AND NOT right)
    and-not: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Three-valued AND (Kleene logic)
    and-kleene: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Three-valued OR (Kleene logic)
    or-kleene: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Check which values are null
    is-null: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Check which values are not null
    is-not-null: func(arr: borrow<array>) -> result<array, arrow-error>;

    // ========================================================================
    // Bitwise Operations (arrow-arith bitwise)
    // ========================================================================

    /// Bitwise AND of two arrays
    bitwise-and: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Bitwise OR of two arrays
    bitwise-or: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Bitwise XOR of two arrays
    bitwise-xor: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Bitwise NOT of array
    bitwise-not: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Bitwise AND NOT
    bitwise-and-not: func(left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Bitwise shift left
    bitwise-shift-left: func(arr: borrow<array>, shift: borrow<array>) -> result<array, arrow-error>;

    /// Bitwise shift right
    bitwise-shift-right: func(arr: borrow<array>, shift: borrow<array>) -> result<array, arrow-error>;

    // ========================================================================
    // Sorting Operations (arrow-ord sort)
    // ========================================================================

    /// Sort options
    record sort-options {
        /// Sort in descending order
        descending: bool,
        /// Put nulls first
        nulls-first: bool,
    }

    /// Sort array and return indices
    sort-to-indices: func(arr: borrow<array>, options: option<sort-options>) -> result<array, arrow-error>;

    /// Sort array values
    sort: func(arr: borrow<array>, options: option<sort-options>) -> result<array, arrow-error>;

    /// Sort array with limit (partial sort)
    sort-limit: func(arr: borrow<array>, options: option<sort-options>, limit: u64) -> result<array, arrow-error>;

    /// Lexicographic sort of multiple arrays (returns indices)
    lexsort: func(arrays: list<borrow<array>>, options: list<sort-options>) -> result<array, arrow-error>;

    /// Compute rank of each element
    rank: func(arr: borrow<array>, options: option<sort-options>) -> result<array, arrow-error>;

    // ========================================================================
    // Selection Operations (arrow-select)
    // ========================================================================

    /// Filter array by boolean mask
    filter: func(arr: borrow<array>, predicate: borrow<array>) -> result<array, arrow-error>;

    /// Filter record batch by boolean mask
    filter-record-batch: func(batch: borrow<record-batch>, predicate: borrow<array>) -> result<record-batch, arrow-error>;

    /// Take values at specified indices
    take: func(arr: borrow<array>, indices: borrow<array>) -> result<array, arrow-error>;

    /// Take rows from record batch at specified indices
    take-record-batch: func(batch: borrow<record-batch>, indices: borrow<array>) -> result<record-batch, arrow-error>;

    /// Concatenate arrays
    concat: func(arrays: list<borrow<array>>) -> result<array, arrow-error>;

    /// Concatenate record batches
    concat-batches: func(batches: list<borrow<record-batch>>) -> result<record-batch, arrow-error>;

    /// Interleave arrays according to indices
    interleave: func(arrays: list<borrow<array>>, indices: list<tuple<u32, u32>>) -> result<array, arrow-error>;

    /// Return null where predicate is true, otherwise return original value
    nullif: func(arr: borrow<array>, predicate: borrow<array>) -> result<array, arrow-error>;

    /// Zip two arrays based on boolean selector (if true take left, else right)
    zip: func(predicate: borrow<array>, left: borrow<array>, right: borrow<array>) -> result<array, arrow-error>;

    /// Shift array values by offset (positive = shift right, negative = shift left)
    shift: func(arr: borrow<array>, offset: s64) -> result<array, arrow-error>;

    // ========================================================================
    // String Operations (arrow-string)
    // ========================================================================

    /// Get length of each string in characters
    string-length: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Get length of each value in bits
    bit-length: func(arr: borrow<array>) -> result<array, arrow-error>;

    /// Check if strings match LIKE pattern
    string-like: func(arr: borrow<array>, pattern: string) -> result<array, arrow-error>;

    /// Check if strings match ILIKE pattern (case-insensitive)
    string-ilike: func(arr: borrow<array>, pattern: string) -> result<array, arrow-error>;

    /// Check if strings do NOT match LIKE pattern
    string-nlike: func(arr: borrow<array>, pattern: string) -> result<array, arrow-error>;

    /// Check if strings do NOT match ILIKE pattern
    string-nilike: func(arr: borrow<array>, pattern: string) -> result<array, arrow-error>;

    /// Check if strings start with prefix
    string-starts-with: func(arr: borrow<array>, prefix: string) -> result<array, arrow-error>;

    /// Check if strings end with suffix
    string-ends-with: func(arr: borrow<array>, suffix: string) -> result<array, arrow-error>;

    /// Check if strings contain substring
    string-contains: func(arr: borrow<array>, substring: string) -> result<array, arrow-error>;

    /// Check if strings match regex pattern
    regexp-is-match: func(arr: borrow<array>, pattern: string) -> result<array, arrow-error>;

    /// Extract regex matches
    regexp-match: func(arr: borrow<array>, pattern: string) -> result<array, arrow-error>;

    /// Extract substring by character position
    substring: func(arr: borrow<array>, start: s64, length: option<u64>) -> result<array, arrow-error>;

    /// Concatenate string arrays element-wise
    concat-elements: func(arrays: list<borrow<array>>) -> result<array, arrow-error>;

    // ========================================================================
    // Temporal Operations (arrow-arith temporal)
    // ========================================================================

    /// Date/time part to extract
    enum date-part {
        year,
        quarter,
        month,
        week,
        day,
        day-of-week-sunday0,
        day-of-week-monday0,
        day-of-year,
        hour,
        minute,
        second,
        millisecond,
        microsecond,
        nanosecond,
    }

    /// Extract date/time part from temporal array
    extract-date-part: func(arr: borrow<array>, part: date-part) -> result<array, arrow-error>;

    // ========================================================================
    // Cast Operations (arrow-cast)
    // ========================================================================

    /// Cast array to different data type
    cast: func(arr: borrow<array>, to-type: data-type) -> result<array, arrow-error>;

    /// Check if cast is possible between types
    can-cast: func(from-type: data-type, to-type: data-type) -> bool;

    // ========================================================================
    // In-List Operations (arrow-ord)
    // ========================================================================

    /// Check if values are in list of i64 values
    in-list-i64: func(arr: borrow<array>, values: list<s64>) -> result<array, arrow-error>;

    /// Check if values are in list of strings
    in-list-string: func(arr: borrow<array>, values: list<string>) -> result<array, arrow-error>;

    // ========================================================================
    // Utility Operations
    // ========================================================================

    /// Count non-null values
    count: func(arr: borrow<array>) -> u64;

    /// Count null values
    null-count: func(arr: borrow<array>) -> u64;

    /// Get array length
    len: func(arr: borrow<array>) -> u64;

    /// Check if array is empty
    is-empty: func(arr: borrow<array>) -> bool;
}
